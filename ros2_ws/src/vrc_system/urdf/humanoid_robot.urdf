<?xml version="1.0"?>
<robot name="humanoid_robot">

  <!-- BASE -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- TORSO -->
  <link name="torso">
    <visual>
      <geometry>
        <box size="0.3 0.2 0.5"/>
      </geometry>
      <origin xyz="0 0 0.35"/>
      <material name="green"/>
    </visual>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <!-- HEAD -->
  <link name="head">
    <visual>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <origin xyz="0 0 0.75"/>
      <material name="white"/>
    </visual>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- LEFT ARM -->
  <link name="left_arm">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.35"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_arm_joint" type="fixed">
    <parent link="torso"/>
    <child link="left_arm"/>
    <origin xyz="0 0.18 0.45"/>
  </joint>

  <!-- RIGHT ARM -->
  <link name="right_arm">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.35"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_arm_joint" type="fixed">
    <parent link="torso"/>
    <child link="right_arm"/>
    <origin xyz="0 -0.18 0.45"/>
  </joint>

  <!-- LEFT LEG -->
  <link name="left_leg">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.45"/>
      </geometry>
      <origin xyz="0 0 -0.22"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg"/>
    <origin xyz="0 0.08 0"/>
  </joint>

  <!-- RIGHT LEG -->
  <link name="right_leg">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.45"/>
      </geometry>
      <origin xyz="0 0 -0.22"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>
    <origin xyz="0 -0.08 0"/>
  </joint>

  <!-- COLORS -->
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>

  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

</robot>
