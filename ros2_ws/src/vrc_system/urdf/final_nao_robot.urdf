<?xml version="1.0"?>
<robot name="final_nao_robot">

  <!-- ================= MATERIALS ================= -->
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <material name="red">
    <color rgba="1 0.2 0.2 1"/>
  </material>

  <material name="dark">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.28 0.20 0.08"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.28 0.20 0.08"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.2" iyy="0.2" izz="0.2"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= TORSO ================= -->
  <link name="torso">
    <visual>
      <origin xyz="0 0 0.22"/>
      <geometry>
        <box size="0.20 0.16 0.32"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
  </joint>

  <!-- ================= HEAD ================= -->
  <link name="head">
    <visual>
      <origin xyz="0 0 0.46"/>
      <geometry>
        <sphere radius="0.10"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
  </joint>

  <!-- ================= HEAD CAP ================= -->
  <link name="head_cap">
    <visual>
      <origin xyz="0 0 0.53"/>
      <geometry>
        <box size="0.12 0.12 0.03"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <joint name="head_cap_joint" type="fixed">
    <parent link="head"/>
    <child link="head_cap"/>
  </joint>

  <!-- ================= LEFT ARM ================= -->
  <link name="left_arm">
    <visual>
      <origin xyz="0 0.15 0.28" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.025" length="0.22"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="left_arm_joint" type="fixed">
    <parent link="torso"/>
    <child link="left_arm"/>
  </joint>

  <!-- ================= RIGHT ARM ================= -->
  <link name="right_arm">
    <visual>
      <origin xyz="0 -0.15 0.28" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.025" length="0.22"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="right_arm_joint" type="fixed">
    <parent link="torso"/>
    <child link="right_arm"/>
  </joint>

  <!-- ================= LEFT LEG ================= -->
  <link name="left_leg">
    <visual>
      <origin xyz="0 0.06 -0.18"/>
      <geometry>
        <cylinder radius="0.03" length="0.25"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="left_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg"/>
  </joint>

  <!-- ================= RIGHT LEG ================= -->
  <link name="right_leg">
    <visual>
      <origin xyz="0 -0.06 -0.18"/>
      <geometry>
        <cylinder radius="0.03" length="0.25"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="right_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>
  </joint>

  <!-- ================= LEFT FOOT ================= -->
  <link name="left_foot">
    <visual>
      <origin xyz="0 0.06 -0.32"/>
      <geometry>
        <box size="0.10 0.06 0.03"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="left_foot_joint" type="fixed">
    <parent link="left_leg"/>
    <child link="left_foot"/>
  </joint>

  <!-- ================= RIGHT FOOT ================= -->
  <link name="right_foot">
    <visual>
      <origin xyz="0 -0.06 -0.32"/>
      <geometry>
        <box size="0.10 0.06 0.03"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="right_foot_joint" type="fixed">
    <parent link="right_leg"/>
    <child link="right_foot"/>
  </joint>

  <!-- ================= LEFT WHEEL ================= -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <material name="dark"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.12 -0.04"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= RIGHT WHEEL ================= -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <material name="dark"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.045" length="0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
    </collision>

    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.12 -0.04"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= DIFF DRIVE ================= -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_diameter>0.09</wheel_diameter>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

</robot>
