<?xml version="1.0"?>
<robot name="moving_humanoid_robot">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.2"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= TORSO ================= -->
  <link name="torso">
    <visual>
      <origin xyz="0 0 0.35"/>
      <geometry>
        <box size="0.3 0.2 0.5"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="base_link"/>
    <child link="torso"/>
  </joint>

  <!-- ================= HEAD ================= -->
  <link name="head">
    <visual>
      <origin xyz="0 0 0.75"/>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
  </joint>

  <!-- ================= LEFT ARM ================= -->
  <link name="left_arm">
    <visual>
      <origin xyz="0 0.22 0.45" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.04" length="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_arm_joint" type="fixed">
    <parent link="torso"/>
    <child link="left_arm"/>
  </joint>

  <!-- ================= RIGHT ARM ================= -->
  <link name="right_arm">
    <visual>
      <origin xyz="0 -0.22 0.45" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.04" length="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_arm_joint" type="fixed">
    <parent link="torso"/>
    <child link="right_arm"/>
  </joint>

  <!-- ================= LEFT LEG ================= -->
  <link name="left_leg">
    <visual>
      <origin xyz="0 0.08 -0.25"/>
      <geometry>
        <cylinder radius="0.05" length="0.4"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg"/>
  </joint>

  <!-- ================= RIGHT LEG ================= -->
  <link name="right_leg">
    <visual>
      <origin xyz="0 -0.08 -0.25"/>
      <geometry>
        <cylinder radius="0.05" length="0.4"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_leg_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>
  </joint>

  <!-- ================= LEFT WHEEL ================= -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0.18 -0.12" rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.18 -0.12"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= RIGHT WHEEL ================= -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 -0.18 -0.12" rpy="1.57 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.18 -0.12"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ================= GAZEBO DIFF DRIVE ================= -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.36</wheel_separation>
      <wheel_diameter>0.14</wheel_diameter>

      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

</robot>
