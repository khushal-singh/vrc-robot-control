<?xml version="1.0"?>
<robot name="advanced_humanoid_robot_v3">

  <!-- =============== MATERIALS =============== -->
  <material name="white">
    <color rgba="0.96 0.96 0.96 1"/>
  </material>

  <material name="red">
    <color rgba="0.9 0.2 0.2 1"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <material name="gray">
    <color rgba="0.4 0.4 0.4 1"/>
  </material>

  <material name="blue">
    <color rgba="0.1 0.4 0.9 1"/>
  </material>

  <!-- Gazebo materials for key colored parts -->
  <gazebo reference="chest_panel">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="head_top">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- =============== BASE =============== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.24 0.18 0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.24 0.18 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.3" iyy="0.3" izz="0.3"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- =============== PELVIS / LOWER TORSO =============== -->
  <link name="pelvis">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.20 0.14 0.08"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.20 0.14 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.04" iyy="0.04" izz="0.03"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="pelvis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pelvis"/>
    <origin xyz="0 0 0.12"/>
  </joint>

  <!-- Hip red pads -->
  <link name="left_hip_pad">
    <visual>
      <origin xyz="0 0.11 0"/>
      <geometry>
        <box size="0.02 0.05 0.06"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0.11 0"/>
      <geometry>
        <box size="0.02 0.05 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0.11 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_hip_pad_joint" type="fixed">
    <parent link="pelvis"/>
    <child link="left_hip_pad"/>
  </joint>

  <link name="right_hip_pad">
    <visual>
      <origin xyz="0 -0.11 0"/>
      <geometry>
        <box size="0.02 0.05 0.06"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 -0.11 0"/>
      <geometry>
        <box size="0.02 0.05 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 -0.11 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_hip_pad_joint" type="fixed">
    <parent link="pelvis"/>
    <child link="right_hip_pad"/>
  </joint>

  <!-- =============== WAIST =============== -->
  <link name="waist">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.18 0.13 0.06"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.18 0.13 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.02" iyy="0.02" izz="0.015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="waist_joint" type="fixed">
    <parent link="pelvis"/>
    <child link="waist"/>
    <origin xyz="0 0 0.07"/>
  </joint>

  <!-- =============== UPPER TORSO =============== -->
  <link name="torso">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.20 0.18 0.18"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.20 0.18 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.03" iyy="0.03" izz="0.025"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="torso_joint" type="fixed">
    <parent link="waist"/>
    <child link="torso"/>
    <origin xyz="0 0 0.12"/>
  </joint>

  <!-- Chest red panel -->
  <link name="chest_panel">
    <visual>
      <origin xyz="0.11 0 0"/>
      <geometry>
        <box size="0.02 0.12 0.14"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0.11 0 0"/>
      <geometry>
        <box size="0.02 0.12 0.14"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0.11 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="chest_panel_joint" type="fixed">
    <parent link="torso"/>
    <child link="chest_panel"/>
  </joint>

  <!-- =============== HEAD =============== -->
  <link name="head">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.11"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.11"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="head_joint" type="fixed">
    <parent link="torso"/>
    <child link="head"/>
    <origin xyz="0 0 0.22"/>
  </joint>

  <link name="head_visor">
    <visual>
      <origin xyz="0.09 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.14 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.09 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.14 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0.09 0 0"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="head_visor_joint" type="fixed">
    <parent link="head"/>
    <child link="head_visor"/>
  </joint>

  <!-- Head top red plate -->
  <link name="head_top">
    <visual>
      <origin xyz="0 0 0.13"/>
      <geometry>
        <box size="0.13 0.13 0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.13"/>
      <geometry>
        <box size="0.13 0.13 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0.13"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="head_top_joint" type="fixed">
    <parent link="head"/>
    <child link="head_top"/>
  </joint>

  <!-- Eyes -->
  <link name="left_eye">
    <visual>
      <origin xyz="0.12 0.045 0.04"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.12 0.045 0.04"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.12 0.045 0.04"/>
      <inertia ixx="0.00003" iyy="0.00003" izz="0.00003"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_eye_joint" type="fixed">
    <parent link="head"/>
    <child link="left_eye"/>
  </joint>

   <link name="right_eye">
    <visual>
      <origin xyz="0.12 -0.045 0.04"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.12 -0.045 0.04"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.12 -0.045 0.04"/>
      <inertia ixx="0.00003" iyy="0.00003" izz="0.00003"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_eye_joint" type="fixed">
    <parent link="head"/>
    <child link="right_eye"/>
  </joint>

  <!-- Mouth -->
  <link name="mouth">
    <visual>
      <origin xyz="0.12 0 -0.04"/>
      <geometry>
        <box size="0.06 0.015 0.012"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.12 0 -0.04"/>
      <geometry>
        <box size="0.06 0.015 0.012"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.12 0 -0.04"/>
      <inertia ixx="0.00003" iyy="0.00003" izz="0.00003"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="mouth_joint" type="fixed">
    <parent link="head"/>
    <child link="mouth"/>
  </joint>
  <!-- Nose -->
  <link name="nose">
    <visual>
      <origin xyz="0.125 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0.125 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0.125 0 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="nose_joint" type="fixed">
    <parent link="head"/>
    <child link="nose"/>
  </joint>

  <!-- Eyebrows -->
  <link name="left_eyebrow">
    <visual>
      <origin xyz="0.115 0.045 0.07"/>
      <geometry>
        <box size="0.05 0.01 0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="left_eyebrow_joint" type="fixed">
    <parent link="head"/>
    <child link="left_eyebrow"/>
  </joint>

  <link name="right_eyebrow">
    <visual>
      <origin xyz="0.115 -0.045 0.07"/>
      <geometry>
        <box size="0.05 0.01 0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_eyebrow_joint" type="fixed">
    <parent link="head"/>
    <child link="right_eyebrow"/>
  </joint>

  <!-- =============== SHOULDERS AND ARMS =============== -->
  <link name="left_shoulder_plate">
    <visual>
      <origin xyz="0 0.15 0.04"/>
      <geometry>
        <box size="0.10 0.06 0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0.15 0.04"/>
      <geometry>
        <box size="0.10 0.06 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0.15 0.04"/>
      <inertia ixx="0.0008" iyy="0.0008" izz="0.0008"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_shoulder_plate_joint" type="fixed">
    <parent link="torso"/>
    <child link="left_shoulder_plate"/>
    <origin xyz="0 0 0.06"/>
  </joint>

  <link name="left_shoulder">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0015" iyy="0.0015" izz="0.0015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Shoulder pitch: rotate arm forward/back -->
  <joint name="left_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_shoulder"/>
    <origin xyz="0 0.16 0.06"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2.0"/>
  </joint>

  <!-- Upper arm -->
    <link name="left_upper_arm">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.12"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.06"/>
      <inertia ixx="0.0012" iyy="0.0012" izz="0.0012"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Shoulder to upper arm -->
  <joint name="left_upper_arm_joint" type="revolute">
    <parent link="left_shoulder"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0 -0.04"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2.0"/>
  </joint>

  <!-- Elbow ring -->
  <link name="left_elbow_ring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.028" length="0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.028" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00015" iyy="0.00015" izz="0.00015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Elbow joint -->
   <joint name="left_elbow_joint" type="revolute">
    <parent link="left_upper_arm"/>
    <child link="left_elbow_ring"/>
    <origin xyz="0 0 -0.12"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.5" effort="5" velocity="2.0"/>
  </joint>

  <!-- Forearm -->
   <link name="left_forearm">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 -0.06"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Elbow to forearm (fixed, just offsets geometry) -->
  <joint name="left_forearm_joint" type="fixed">
    <parent link="left_elbow_ring"/>
    <child link="left_forearm"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="left_wrist">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00008" iyy="0.00008" izz="0.00008"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_wrist_joint" type="revolute">
    <parent link="left_forearm"/>
    <child link="left_wrist"/>
    <origin xyz="0 0 -0.12"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.2" upper="1.2" effort="2" velocity="2.0"/>
  </joint>

  <!-- Smaller palm -->
  <link name="left_palm">
    <visual>
      <origin xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0.04 0 0"/>
      <inertia ixx="0.0004" iyy="0.0004" izz="0.0004"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_palm_joint" type="fixed">
    <parent link="left_wrist"/>
    <child link="left_palm"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- Shorter fingers -->
  <link name="left_finger1">
    <visual>
      <origin xyz="0.06 0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0.06 0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.06 0.025 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_finger1_joint" type="revolute">
    <parent link="left_palm"/>
    <child link="left_finger1"/>
    <origin xyz="0.04 0.02 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.7" effort="1" velocity="2.0"/>
  </joint>

  <link name="left_finger2">
    <visual>
      <origin xyz="0.06 -0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0.06 -0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.06 -0.025 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_finger2_joint" type="revolute">
    <parent link="left_palm"/>
    <child link="left_finger2"/>
    <origin xyz="0.04 -0.02 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0" upper="0.7" effort="1" velocity="2.0"/>
  </joint>

     <!-- =============== RIGHT ARM (SHORTER, MIRROR OF LEFT) =============== -->
  <link name="right_shoulder_plate">
    <visual>
      <origin xyz="0 -0.15 0.04"/>
      <geometry>
        <box size="0.10 0.06 0.02"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 -0.15 0.04"/>
      <geometry>
        <box size="0.10 0.06 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 -0.15 0.04"/>
      <inertia ixx="0.0008" iyy="0.0008" izz="0.0008"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_shoulder_plate_joint" type="fixed">
    <parent link="torso"/>
    <child link="right_shoulder_plate"/>
    <origin xyz="0 0 0.06"/>
  </joint>

  <link name="right_shoulder">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0015" iyy="0.0015" izz="0.0015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_shoulder"/>
    <origin xyz="0 -0.16 0.06"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2.0"/>
  </joint>

  <!-- Shorter upper arm -->
  <link name="right_upper_arm">
    <visual>
      <origin xyz="0 0 -0.09" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.12"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.09"/>
      <inertia ixx="0.0012" iyy="0.0012" izz="0.0012"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_upper_arm_joint" type="revolute">
    <parent link="right_shoulder"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 0 -0.04"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2.0"/>
  </joint>

  <link name="right_elbow_ring">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.028" length="0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 1.57"/>
      <geometry>
        <cylinder radius="0.028" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00015" iyy="0.00015" izz="0.00015"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_elbow_joint" type="revolute">
    <parent link="right_upper_arm"/>
    <child link="right_elbow_ring"/>
    <origin xyz="0 0 -0.12"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.5" effort="5" velocity="2.0"/>
  </joint>

  <!-- Shorter forearm -->
   <link name="right_forearm">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 -0.06"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>


  <joint name="right_forearm_joint" type="fixed">
    <parent link="right_elbow_ring"/>
    <child link="right_forearm"/>
    <origin xyz="0 0 0"/>
  </joint>

  <link name="right_wrist">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.08"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00008" iyy="0.00008" izz="0.00008"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

 <joint name="right_wrist_joint" type="revolute">
    <parent link="right_forearm"/>
    <child link="right_wrist"/>
    <origin xyz="0 0 -0.12"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.2" upper="1.2" effort="2" velocity="2.0"/>
  </joint>

  <!-- Smaller palm -->
  <link name="right_palm">
    <visual>
      <origin xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0.04 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0.04 0 0"/>
      <inertia ixx="0.0004" iyy="0.0004" izz="0.0004"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_palm_joint" type="fixed">
    <parent link="right_wrist"/>
    <child link="right_palm"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- Shorter fingers -->
  <link name="right_finger1">
    <visual>
      <origin xyz="0.06 0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0.06 0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.06 0.025 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_finger1_joint" type="revolute">
    <parent link="right_palm"/>
    <child link="right_finger1"/>
    <origin xyz="0.04 0.02 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.7" effort="1" velocity="2.0"/>
  </joint>

  <link name="right_finger2">
    <visual>
      <origin xyz="0.06 -0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0.06 -0.025 0"/>
      <geometry>
        <box size="0.04 0.012 0.012"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0.06 -0.025 0"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_finger2_joint" type="revolute">
    <parent link="right_palm"/>
    <child link="right_finger2"/>
    <origin xyz="0.04 -0.02 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0" upper="0.7" effort="1" velocity="2.0"/>
  </joint>


  <!-- =============== WHEELS (no plugin for now) =============== -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.12 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.035"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.12 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- =============== GAZEBO PLUGINS =============== -->
  <gazebo>
  <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

    <left_joint>left_wheel_joint</left_joint>
    <right_joint>right_wheel_joint</right_joint>

    <wheel_separation>0.24</wheel_separation>
    <wheel_radius>0.06</wheel_radius>
    <wheel_diameter>0.12</wheel_diameter>

    <robot_base_frame>base_link</robot_base_frame>

    <command_topic>cmd_vel</command_topic>
    <odometry_topic>odom</odometry_topic>
    <odometry_frame>odom</odometry_frame>

    <publish_tf>true</publish_tf>
    <publish_odom>true</publish_odom>

    <max_wheel_torque>20</max_wheel_torque>
    <max_wheel_acceleration>5.0</max_wheel_acceleration>

  </plugin>
</gazebo>
</robot>
