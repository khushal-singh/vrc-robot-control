<?xml version="1.0"?>
<robot name="advanced_humanoid_robot_v3">

  <!-- =============== MATERIALS =============== -->
  <material name="white"><color rgba="0.96 0.96 0.96 1"/></material>
  <material name="red"><color rgba="0.9 0.2 0.2 1"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
  <material name="gray"><color rgba="0.4 0.4 0.4 1"/></material>
  <material name="blue"><color rgba="0.1 0.4 0.9 1"/></material>

  <!-- =============== BASE =============== -->
  <link name="base_link">
    <visual><geometry><box size="0.24 0.18 0.08"/></geometry><material name="black"/></visual>
    <collision><geometry><box size="0.24 0.18 0.08"/></geometry></collision>
    <inertial><mass value="5"/><origin xyz="0 0 0"/>
      <inertia ixx="0.25" iyy="0.25" izz="0.25"/></inertial>
  </link>

  <!-- pelvis -->
  <link name="pelvis">
    <visual><geometry><box size="0.20 0.14 0.08"/></geometry><material name="white"/></visual>
    <collision><geometry><box size="0.20 0.14 0.08"/></geometry></collision>
    <inertial><mass value="3"/><origin xyz="0 0 0"/>
      <inertia ixx="0.03" iyy="0.03" izz="0.02"/></inertial>
  </link>

  <joint name="pelvis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pelvis"/>
    <origin xyz="0 0 0.12"/>
  </joint>

  <!-- ===== COMMON INERTIAL TEMPLATE ===== -->
  <!-- Using same inertial for all cosmetic links -->

  <!-- hip pads -->
  <link name="left_hip_pad">
    <visual><origin xyz="0 0.11 0"/><geometry><box size="0.02 0.05 0.06"/></geometry><material name="red"/></visual>
    <collision><origin xyz="0 0.11 0"/><geometry><box size="0.02 0.05 0.06"/></geometry></collision>
    <inertial><mass value="0.2"/><origin xyz="0 0 0"/><inertia ixx="0.001" iyy="0.001" izz="0.001"/></inertial>
  </link>
  <joint name="left_hip_pad_joint" type="fixed"><parent link="pelvis"/><child link="left_hip_pad"/></joint>

  <link name="right_hip_pad">
    <visual><origin xyz="0 -0.11 0"/><geometry><box size="0.02 0.05 0.06"/></geometry><material name="red"/></visual>
    <collision><origin xyz="0 -0.11 0"/><geometry><box size="0.02 0.05 0.06"/></geometry></collision>
    <inertial><mass value="0.2"/><origin xyz="0 0 0"/><inertia ixx="0.001" iyy="0.001" izz="0.001"/></inertial>
  </link>
  <joint name="right_hip_pad_joint" type="fixed"><parent link="pelvis"/><child link="right_hip_pad"/></joint>

  <!-- waist -->
  <link name="waist">
    <visual><geometry><box size="0.18 0.13 0.06"/></geometry><material name="white"/></visual>
    <collision><geometry><box size="0.18 0.13 0.06"/></geometry></collision>
    <inertial><mass value="1"/><origin xyz="0 0 0"/><inertia ixx="0.01" iyy="0.01" izz="0.01"/></inertial>
  </link>
  <joint name="waist_joint" type="fixed"><parent link="pelvis"/><child link="waist"/><origin xyz="0 0 0.07"/></joint>

  <!-- torso -->
  <link name="torso">
    <visual><geometry><box size="0.20 0.18 0.18"/></geometry><material name="white"/></visual>
    <collision><geometry><box size="0.20 0.18 0.18"/></geometry></collision>
    <inertial><mass value="2"/><origin xyz="0 0 0"/><inertia ixx="0.02" iyy="0.02" izz="0.02"/></inertial>
  </link>
  <joint name="torso_joint" type="fixed"><parent link="waist"/><child link="torso"/><origin xyz="0 0 0.12"/></joint>

  <!-- head -->
  <link name="head">
    <visual><geometry><sphere radius="0.11"/></geometry><material name="white"/></visual>
    <collision><geometry><sphere radius="0.11"/></geometry></collision>
    <inertial><mass value="1"/><origin xyz="0 0 0"/><inertia ixx="0.01" iyy="0.01" izz="0.01"/></inertial>
  </link>
  <joint name="head_joint" type="fixed"><parent link="torso"/><child link="head"/><origin xyz="0 0 0.22"/></joint>

  <!-- arms -->
  <link name="left_shoulder">
    <visual><geometry><sphere radius="0.055"/></geometry><material name="red"/></visual>
    <collision><geometry><sphere radius="0.055"/></geometry></collision>
    <inertial><mass value="0.5"/><origin xyz="0 0 0"/><inertia ixx="0.002" iyy="0.002" izz="0.002"/></inertial>
  </link>

  <joint name="left_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="left_shoulder"/>
    <origin xyz="0 0.16 0.06"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2"/>
  </joint>

  <link name="left_arm">
    <visual><origin rpy="0 0 1.57"/><geometry><cylinder radius="0.022" length="0.24"/></geometry><material name="white"/></visual>
    <collision><origin rpy="0 0 1.57"/><geometry><cylinder radius="0.022" length="0.24"/></geometry></collision>
    <inertial><mass value="0.8"/><origin xyz="0 0 0"/><inertia ixx="0.005" iyy="0.005" izz="0.005"/></inertial>
  </link>
  <joint name="left_arm_joint" type="fixed"><parent link="left_shoulder"/><child link="left_arm"/></joint>

  <link name="right_shoulder">
    <visual><geometry><sphere radius="0.055"/></geometry><material name="red"/></visual>
    <collision><geometry><sphere radius="0.055"/></geometry></collision>
    <inertial><mass value="0.5"/><origin xyz="0 0 0"/><inertia ixx="0.002" iyy="0.002" izz="0.002"/></inertial>
  </link>

  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso"/>
    <child link="right_shoulder"/>
    <origin xyz="0 -0.16 0.06"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="5" velocity="2"/>
  </joint>

  <link name="right_arm">
    <visual><origin rpy="0 0 1.57"/><geometry><cylinder radius="0.022" length="0.24"/></geometry><material name="white"/></visual>
    <collision><origin rpy="0 0 1.57"/><geometry><cylinder radius="0.022" length="0.24"/></geometry></collision>
    <inertial><mass value="0.8"/><origin xyz="0 0 0"/><inertia ixx="0.005" iyy="0.005" izz="0.005"/></inertial>
  </link>
  <joint name="right_arm_joint" type="fixed"><parent link="right_shoulder"/><child link="right_arm"/></joint>

  <!-- wheels -->
  <link name="left_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.06" length="0.035"/></geometry><material name="black"/></visual>
    <collision><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.06" length="0.035"/></geometry></collision>
    <inertial><mass value="1"/><origin xyz="0 0 0"/><inertia ixx="0.01" iyy="0.01" izz="0.01"/></inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="pelvis"/>
    <child link="left_wheel"/>
    <origin xyz="-0.02 0.12 -0.06"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.06" length="0.035"/></geometry><material name="black"/></visual>
    <collision><origin rpy="1.57 0 0"/><geometry><cylinder radius="0.06" length="0.035"/></geometry></collision>
    <inertial><mass value="1"/><origin xyz="0 0 0"/><inertia ixx="0.01" iyy="0.01" izz="0.01"/></inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="pelvis"/>
    <child link="right_wheel"/>
    <origin xyz="-0.02 -0.12 -0.06"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- plugin -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_wheel_joint>left_wheel_joint</left_wheel_joint>
      <right_wheel_joint>right_wheel_joint</right_wheel_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>
      <robot_base_frame>base_link</robot_base_frame>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <publish_tf>true</publish_tf>
    </plugin>
  </gazebo>

</robot>