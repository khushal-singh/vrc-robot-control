          <geometry><cylinder><radius>0.18</radius><length>0.4</length></cylinder></geometry>
          <material>
            <ambient>0.05 0.25 0.75 1</ambient>
            <diffuse>0.05 0.25 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Laptop (flat box) on student desk 2b -->
    <model name="laptop_body">
      <static>true</static>
      <link name="link">
        <pose>0 -1.2 0.775 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.33 0.22 0.02</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.33 0.22 0.02</size></box></geometry>
          <material>
            <ambient>0.2 0.2 0.22 1</ambient>
            <diffuse>0.2 0.2 0.22 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Laptop screen (tilted silver panel) -->
    <model name="laptop_screen">
      <static>true</static>
      <link name="link">
        <pose>0 -1.09 0.92 0.75 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.33 0.02 0.22</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.33 0.02 0.22</size></box></geometry>
          <material>
            <ambient>0.15 0.15 0.17 1</ambient>
            <diffuse>0.15 0.15 0.17 1</diffuse>
            <specular>0.6 0.6 0.6 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Projector screen frame on south wall -->
    <model name="projector_screen">
      <static>true</static>
      <link name="link">
        <pose>0 -3.88 1.9 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>2.0 0.04 1.2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>2.0 0.04 1.2</size></box></geometry>
          <material>
            <ambient>0.95 0.95 0.9 1</ambient>
            <diffuse>0.95 0.95 0.9 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Projector screen border -->
    <model name="projector_screen_border">
      <static>true</static>
      <link name="link">
        <pose>0 -3.86 1.9 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>2.1 0.03 1.3</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>2.1 0.03 1.3</size></box></geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ══════════════════════════════════════════
         HUMANOID ROBOT  (Atlas / built-in model)
         Spawned near the centre of the room
    ══════════════════════════════════════════ -->
    <include>
      <uri>model://atlas</uri>
      <name>atlas_robot</name>
      <pose>0 0 0.93 0 0 0</pose>
    </include>

  </world>
</sdf>
