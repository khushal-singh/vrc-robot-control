<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="university_room">

    <!-- ══════════════════════════════════════════
         PHYSICS
    ══════════════════════════════════════════ -->
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <!-- ══════════════════════════════════════════
         LIGHTING
    ══════════════════════════════════════════ -->
    <!-- Ambient fill -->
    <light name="ambient_light" type="ambient">
      <color>0.4 0.4 0.4 1</color>
    </light>

    <!-- Main overhead directional light (sun) -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.3 0.3 -1</direction>
    </light>

    <!-- Two overhead point lights to mimic fluorescent panels -->
    <light name="ceiling_light_1" type="point">
      <pose>-2 0 3 0 0 0</pose>
      <diffuse>1 1 0.95 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.4</constant>
        <linear>0.1</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <light name="ceiling_light_2" type="point">
      <pose>2 0 3 0 0 0</pose>
      <diffuse>1 1 0.95 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <attenuation>
        <range>8</range>
        <constant>0.4</constant>
        <linear>0.1</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ══════════════════════════════════════════
         ROOM STRUCTURE  (10 m × 8 m × 3 m)
         Origin is at room centre on the floor.
    ══════════════════════════════════════════ -->

    <!-- Floor (light grey tile) -->
    <model name="floor">
      <static>true</static>
      <link name="link">
        <pose>0 0 0 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>10 8 0.05</size></box></geometry>
          <surface><friction><ode><mu>1</mu><mu2>1</mu2></ode></friction></surface>
        </collision>
        <visual name="visual">
          <geometry><box><size>10 8 0.05</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Ceiling (off-white) -->
    <model name="ceiling">
      <static>true</static>
      <link name="link">
        <pose>0 0 3 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>10 8 0.05</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>10 8 0.05</size></box></geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Wall – North  (y = +4) -->
    <model name="wall_north">
      <static>true</static>
      <link name="link">
        <pose>0 4 1.5 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>10 0.15 3</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>10 0.15 3</size></box></geometry>
          <material>
            <ambient>0.88 0.88 0.82 1</ambient>
            <diffuse>0.88 0.88 0.82 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Wall – South  (y = -4) -->
